# URL de l'application web Billariz (frontend)
VITE_WEB_APP_URL=https://your-app-url.billariz.com/

# URL de l'API Swagger (pour la page Documentation)
# Développement local :
SWAGGER_URL=http://localhost:8080/v1/v3/api-docs
# Exemple production :
# SWAGGER_URL=https://api.billariz.com/v1/v3/api-docs

# ID HubSpot pour le tracking (optionnel)
VITE_HUBSPOT_ID=your_hubspot_id
